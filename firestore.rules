rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Anyone can create a user (registration)
      allow create: if true;
      // Only the owner can read/update their own document
      // We identify ownership via the userId stored in the document itself
      allow read, update: if true;  // simplified: lock down after testing
    }
  }
}
